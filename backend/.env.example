# Application Configuration
APP_NAME=HackSamrat
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
LOG_LEVEL=info

# Auth Configuration
AUTH_SESSION_TTL_HOURS=24
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_WEBAUTHN_CHALLENGE_TTL_MINUTES=5
AUTH_WEBAUTHN_RP_NAME=HackSamrat
AUTH_WEBAUTHN_RP_ID=localhost
AUTH_WEBAUTHN_ORIGIN=http://localhost:3000

# Security
ENABLE_METRICS=true
ADMIN_AUDIT_TOKEN=replace-me-with-random-string
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Blockchain Integration (Sepolia)
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_CHAIN_NAME=sepolia
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
WALLET_PRIVATE_KEY=YOUR_PRIVATE_KEY
CONTRACT_ADDRESS=0xd9F485c15472b814B868324651DA3f0a144267E7

# Database (PostgreSQL/Neon)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Cache (Redis)
REDIS_URL=redis://default:password@host:port

# Storage (Cloudinary - Free Alternative to S3)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# AI Services
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
