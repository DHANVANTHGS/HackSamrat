generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum UserRoleType {
  PATIENT
  DOCTOR
  ADMIN
  SUPPORT
  CAREGIVER
  INSURER
}

enum MedicalRecordType {
  REPORT
  PRESCRIPTION
  LAB_RESULT
  IMAGING
  DISCHARGE_SUMMARY
  CLAIM_DOCUMENT
  OTHER
}

enum MedicalRecordVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AccessGrantStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AccessScope {
  FULL_RECORDS
  PRESCRIPTIONS
  IMAGING
  INSURANCE
  CLAIMS
  EMERGENCY_ONLY
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCS_VERIFIED
  APPROVED
  REJECTED
  DISBURSED
}

enum NotificationType {
  CLAIM_UPDATE
  PREMIUM_REMINDER
  RECORD_ACCESS
  POLICY_UPDATE
  EMERGENCY_ACCESS
  SYSTEM
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT_SUCCESS
  RECORD_VIEWED
  RECORD_DOWNLOADED
  RECORD_UPLOADED
  ACCESS_GRANTED
  ACCESS_REVOKED
  CLAIM_CREATED
  CLAIM_UPDATED
  EMERGENCY_LOOKUP
  AI_MESSAGE
  BLOCKCHAIN_ANCHORED
}

enum AnchorStatus {
  PENDING
  ANCHORED
  FAILED
}

enum CredentialType {
  WEBAUTHN
  PASSKEY
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuthChallengeType {
  WEBAUTHN_REGISTRATION
  WEBAUTHN_AUTHENTICATION
}

model User {
  id                     String               @id @default(uuid())
  email                  String               @unique
  phone                  String?              @unique
  passwordHash           String?
  failedLoginAttempts    Int                  @default(0)
  lockedUntil            DateTime?
  role                   UserRoleType
  status                 UserStatus           @default(PENDING)
  firstName              String
  lastName               String
  lastLoginAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  patient                Patient?
  doctor                 Doctor?
  sessions               Session[]
  webauthnCredentials    WebAuthnCredential[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  uploadedMedicalRecords MedicalRecord[]
  aiConversations        AIConversation[]
  roleAssignments        UserRole[]
  authChallenges         AuthChallenge[]
  claimStatusHistory     ClaimStatusHistory[]

  @@index([role, status])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Organization {
  id                String            @id @default(uuid())
  name              String
  type              String
  registrationId    String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  hospitals         Hospital[]
  doctors           Doctor[]
  insurancePolicies InsurancePolicy[]

  @@index([type])
}

model Hospital {
  id             String        @id @default(uuid())
  organizationId String?
  name           String
  code           String        @unique
  addressLine1   String?
  city           String?
  state          String?
  country        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  doctors        Doctor[]
}

model Patient {
  id                      String                  @id @default(uuid())
  userId                  String                  @unique
  patientCode             String                  @unique
  dateOfBirth             DateTime?
  gender                  String?
  bloodGroup              String?
  healthSummary           String?
  emergencyContactName    String?
  emergencyContactPhone   String?
  emergencyAccessSettings EmergencyAccessSetting?
  medicalRecords          MedicalRecord[]
  accessGrants            AccessGrant[]
  insurancePolicies       InsurancePolicy[]
  claims                  Claim[]
  aiConversations         AIConversation[]
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
}

model Doctor {
  id                 String               @id @default(uuid())
  userId             String               @unique
  organizationId     String?
  hospitalId         String?
  doctorCode         String               @unique
  specialty          String?
  licenseNumber      String               @unique
  verificationStatus String               @default("PENDING")
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  hospital           Hospital?            @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  verifications      DoctorVerification[]
  uploadedRecords    MedicalRecord[]      @relation("DoctorUploadedRecords")
  accessGrants       AccessGrant[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model DoctorVerification {
  id               String    @id @default(uuid())
  doctorId         String
  verificationType String
  status           String
  verifiedAt       DateTime?
  notes            String?
  doctor           Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Session {
  id           String        @id @default(uuid())
  userId       String
  token        String        @unique
  refreshToken String?       @unique
  status       SessionStatus @default(ACTIVE)
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  lastSeenAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model WebAuthnCredential {
  id             String         @id @default(uuid())
  userId         String
  credentialId   String         @unique
  publicKey      String
  counter        Int            @default(0)
  transports     String[]
  deviceType     String?
  backedUp       Boolean        @default(false)
  credentialType CredentialType @default(WEBAUTHN)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthChallenge {
  id         String            @id @default(uuid())
  userId     String
  type       AuthChallengeType
  challenge  String            @unique
  expiresAt  DateTime
  consumedAt DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, expiresAt])
}

model MedicalRecord {
  id                 String                          @id @default(uuid())
  patientId          String
  uploadedByUserId   String?
  uploadedByDoctorId String?
  title              String
  description        String?
  recordType         MedicalRecordType
  verificationStatus MedicalRecordVerificationStatus @default(PENDING)
  source             String?
  occurredAt         DateTime?
  metadata           Json?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt
  patient            Patient                         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedByUser     User?                           @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  uploadedByDoctor   Doctor?                         @relation("DoctorUploadedRecords", fields: [uploadedByDoctorId], references: [id], onDelete: SetNull)
  files              RecordFile[]

  @@index([patientId, recordType])
}

model RecordFile {
  id              String        @id @default(uuid())
  medicalRecordId String
  storageKey      String        @unique
  originalName    String
  mimeType        String
  fileSizeBytes   Int
  checksumSha256  String?
  uploadedAt      DateTime      @default(now())
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
}

model AccessGrant {
  id            String            @id @default(uuid())
  patientId     String
  doctorId      String?
  grantedToName String?
  grantedToType String?
  scope         AccessScope
  status        AccessGrantStatus @default(ACTIVE)
  reason        String?
  expiresAt     DateTime?
  revokedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        Doctor?           @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([patientId, status])
}

model InsurancePolicy {
  id             String             @id @default(uuid())
  patientId      String
  organizationId String?
  providerName   String
  policyNumber   String             @unique
  planName       String
  coverageLimit  Decimal            @db.Decimal(12, 2)
  usedCoverage   Decimal            @default(0) @db.Decimal(12, 2)
  premiumAmount  Decimal?           @db.Decimal(12, 2)
  validFrom      DateTime
  validTo        DateTime
  metadata       Json?
  patient        Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization   Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  benefits       InsuranceBenefit[]
  claims         Claim[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([patientId, validTo])
}

model InsuranceBenefit {
  id                String          @id @default(uuid())
  insurancePolicyId String
  benefitCode       String
  label             String
  annualLimit       Decimal?        @db.Decimal(12, 2)
  usedAmount        Decimal?        @default(0) @db.Decimal(12, 2)
  description       String?
  insurancePolicy   InsurancePolicy @relation(fields: [insurancePolicyId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([insurancePolicyId, benefitCode])
}

model Claim {
  id                String           @id @default(uuid())
  patientId         String
  insurancePolicyId String?
  claimNumber       String           @unique
  status            ClaimStatus      @default(DRAFT)
  title             String
  description       String?
  amountClaimed     Decimal          @db.Decimal(12, 2)
  amountApproved    Decimal?         @db.Decimal(12, 2)
  insurerReference  String?
  insurerDecisionAt DateTime?
  insurerDecision   String?
  decisionNotes     String?
  payoutAmount      Decimal?         @db.Decimal(12, 2)
  payoutReference   String?
  payoutProcessedAt DateTime?
  submittedAt       DateTime?
  resolvedAt        DateTime?
  metadata          Json?
  patient           Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  insurancePolicy   InsurancePolicy? @relation(fields: [insurancePolicyId], references: [id], onDelete: SetNull)
  documents         ClaimDocument[]
  statusHistory     ClaimStatusHistory[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([patientId, status])
}

model ClaimDocument {
  id            String   @id @default(uuid())
  claimId       String
  storageKey    String   @unique
  originalName  String
  mimeType      String
  fileSizeBytes Int
  uploadedAt    DateTime @default(now())
  claim         Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

model ClaimStatusHistory {
  id          String      @id @default(uuid())
  claimId     String
  actorUserId String?
  fromStatus  ClaimStatus?
  toStatus    ClaimStatus
  note        String?
  metadata    Json?
  createdAt   DateTime    @default(now())
  claim       Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  actorUser   User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([claimId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model EmergencyAccessSetting {
  id                  String   @id @default(uuid())
  patientId           String   @unique
  enabled             Boolean  @default(false)
  allowCriticalOnly   Boolean  @default(true)
  unlockWindowMinutes Int      @default(30)
  notes               String?
  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AuditLog {
  id                String             @id @default(uuid())
  actorUserId       String?
  action            AuditAction
  targetResource    String
  targetResourceId  String?
  ipAddress         String?
  userAgent         String?
  reason            String?
  metadata          Json?
  occurredAt        DateTime           @default(now())
  actorUser         User?              @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  blockchainAnchors BlockchainAnchor[]

  @@index([action, occurredAt])
}

model AIConversation {
  id            String      @id @default(uuid())
  userId        String
  patientId     String?
  title         String?
  lastMessageAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient       Patient?    @relation(fields: [patientId], references: [id], onDelete: SetNull)
  messages      AIMessage[]

  @@index([userId, updatedAt])
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String
  content        String
  grounded       Boolean        @default(false)
  metadata       Json?
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model BlockchainAnchor {
  id               String       @id @default(uuid())
  auditLogId       String?
  sourceEntityType String
  sourceEntityId   String?
  digest           String
  chainName        String
  transactionHash  String?
  status           AnchorStatus @default(PENDING)
  anchoredAt       DateTime?
  failureReason    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  auditLog         AuditLog?    @relation(fields: [auditLogId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}


